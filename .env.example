# Copy to .env and set every value before running the stack.

# MongoDB
MONGO_URI=
MONGO_PORT=

# Backend
PORT=
NODE_ENV=development
CORS_ORIGIN=
API_PREFIX=

# Auth (use a long random secret in production, e.g. openssl rand -base64 48)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Frontend (Vite — required at build time for production images)
VITE_API_URL=
VITE_API_BASE_PATH=

# Vite dev server only: backend origin for API proxy (scheme + host + port)
VITE_DEV_PROXY_TARGET=

# Docker Compose — host port for the frontend container
FRONTEND_PORT=
